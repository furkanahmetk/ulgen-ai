# ============================================
# Sentinel AI - Vercel Frontend Environment Variables
# ============================================
# You can copy the contents of this file and paste it directly 
# into the first key input field in the Vercel "Environment Variables" section.
# Vercel will automatically parse all keys and values.
# ============================================

# The URL of your deployed backend (e.g. Render URL)
NEXT_PUBLIC_API_URL=https://your-backend-url-here.onrender.com

# CSPR.click Application Settings
NEXT_PUBLIC_CSPR_CLICK_APP_NAME="Sentinel AI"
NEXT_PUBLIC_CSPR_CLICK_APP_ID=your_cspr_click_app_id_here

# Casper Network Settings
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test
NEXT_PUBLIC_CASPER_NODE_URL=https://rpc.testnet.casperlabs.io/rpc
