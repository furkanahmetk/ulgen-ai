# ============================================
# Sentinel AI - Backend Configuration
# ============================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Casper Network ---
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test

# --- CSPR.cloud ---
# Your CSPR.cloud API key (used for REST API, MCP Server, and x402 Facilitator auth)
# Get yours at: https://cspr.cloud
CSPR_CLOUD_API_KEY=your_cspr_cloud_api_key_here

# --- CSPR.cloud REST API (Testnet) ---
CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud

# --- Casper MCP Server (Testnet) ---
# Hosted MCP server for on-chain queries (accounts, blocks, deploys, validators, tokens)
# Auth: X-CSPR-Cloud-Api-Key header with CSPR_CLOUD_API_KEY
CASPER_MCP_URL=https://mcp.testnet.cspr.cloud/mcp

# --- CSPR.trade MCP ---
# Public MCP Server for DEX trading and market data (no API key required)
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp

# --- x402 Facilitator ---
# CSPR.cloud x402 Facilitator for autonomous micro-payments
# Auth: Authorization header with CSPR_CLOUD_API_KEY (no separate x402 key needed)
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# --- Odra Smart Contracts ---
# Deployed contract hashes on Casper (after you deploy with cargo-odra)
MARKETPLACE_CONTRACT_HASH=hash-81f425ad385a853f4bc0920329c882738f2c49c15ff6494dcd321aa6c293717a
REGISTRY_CONTRACT_HASH=hash-31da4afad7aed8ef0ad973593de98a13de3855087affd9095e7c35c277c9ce14

# --- Agent Wallet ---
# The secret key path for the agent's Casper wallet (used for autonomous x402 payments)
# NEVER commit the actual key file. Use a testnet faucet key for development.
AGENT_SECRET_KEY_PATH=./agent_keys/secret_key.pem

# --- Publisher Key (x402 Receiver) ---
# The public key of the publisher account to receive x402 payments
PUBLISHER_PUBLIC_KEY=your_publisher_public_key_here

# --- LLM Provider ---
# OpenRouter (Centralized LLM API)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_preferred_model_here

# Google Gemini API (Free Tier) - Deprecated
GOOGLE_API_KEY=your_google_api_key_here
